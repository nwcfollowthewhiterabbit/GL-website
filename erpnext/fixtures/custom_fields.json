[
  {
    "doctype": "Custom Field",
    "dt": "Quotation",
    "fieldname": "website_quote_id",
    "label": "Website Quote ID",
    "fieldtype": "Data",
    "insert_after": "enq_det",
    "read_only": 1,
    "no_copy": 1,
    "unique": 1,
    "description": "Idempotency key from the Green Leaf storefront quote request."
  },
  {
    "doctype": "Custom Field",
    "dt": "Quotation",
    "fieldname": "website_source",
    "label": "Website Source",
    "fieldtype": "Data",
    "insert_after": "website_quote_id",
    "read_only": 1,
    "no_copy": 1,
    "default": "greenleaf-storefront"
  },
  {
    "doctype": "Custom Field",
    "dt": "Quotation",
    "fieldname": "website_customer_email",
    "label": "Website Customer Email",
    "fieldtype": "Data",
    "insert_after": "website_source",
    "read_only": 1,
    "no_copy": 1
  },
  {
    "doctype": "Custom Field",
    "dt": "Quotation",
    "fieldname": "website_payload",
    "label": "Website Payload",
    "fieldtype": "Long Text",
    "insert_after": "website_customer_email",
    "read_only": 1,
    "no_copy": 1,
    "description": "Compact JSON payload received by the storefront API. Keep customer notes in standard ERP fields too."
  },
  {
    "doctype": "Custom Field",
    "dt": "Customer",
    "fieldname": "website_origin",
    "label": "Website Origin",
    "fieldtype": "Data",
    "insert_after": "email_id",
    "read_only": 1,
    "no_copy": 1,
    "default": "greenleaf-storefront"
  },
  {
    "doctype": "Custom Field",
    "dt": "Customer",
    "fieldname": "website_last_quote_request",
    "label": "Website Last Quote Request",
    "fieldtype": "Datetime",
    "insert_after": "website_origin",
    "read_only": 1,
    "no_copy": 1
  }
]
